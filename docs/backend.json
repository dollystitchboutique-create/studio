{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Artisanal jewelry product with stock tracking",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "spec": { "type": "string" },
        "color": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number", "description": "Current stock level" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isDeleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sku", "name", "price", "quantity"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Transaction record with discount tracking",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["Cash", "Paylah", "PayNow"] },
        "discount": { "type": "number" },
        "discountType": { "type": "string", "enum": ["amount", "percent"] },
        "total": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isDeleted": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sku": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "discount": { "type": "number" },
              "discountType": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalogue for Dollystitch Hub"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records for Dollystitch Hub"
    }
  }
}